// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEAM
  CLIENT
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum PipelineStage {
  LEAD_IDENTIFICATION
  ONBOARDING_PROPOSAL
  REQUIREMENTS_DISCOVERY
  DOCUMENTATION
  PAYMENT_STRUCTURING
  UI_DESIGN
  ARCHITECTURE
  PROJECT_EXECUTION
  FINAL_PAYMENT
  DEPLOYMENT
  LOST
  WON
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          UserRole  @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  client            Client?   @relation("UserToClient")
  sentMessages      Message[] @relation("SentMessages")
  receivedMessages  Message[] @relation("ReceivedMessages")
  notifications     Notification[]
  assignedMilestones Milestone[] @relation("AssignedTo")
}

model Client {
  id            String    @id @default(cuid())
  companyName   String
  contactPerson String
  email         String    @unique
  phone         String?
  status        String    @default("Pipeline") // Pipeline or Onboarded
  revenue       Float     @default(0)
  industry      String?
  currency      String    @default("INR")
  
  userId        String?   @unique
  user          User?     @relation("UserToClient", fields: [userId], references: [id])
  
  projects      Project[]
  pipelines     Pipeline[]
  invoices      Invoice[]
  payments      Payment[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Project {
  id            String        @id @default(cuid())
  name          String
  description   String?
  status        ProjectStatus @default(PENDING)
  progress      Int           @default(0)
  goal          Int           @default(100)
  stretchGoal   Int           @default(120)
  startDate     DateTime      @default(now())
  endDate       DateTime?
  
  totalValue    Float         @default(0)
  advanceAmount Float         @default(0)
  
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  milestones    Milestone[]
  invoices      Invoice[]
  billingStages BillingStage[]
  expenses      Expense[]
  payments      Payment[]
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model BillingStage {
  id            String    @id @default(cuid())
  name          String
  description   String?
  order         Int       @default(0)
  price         Float     @default(0)
  isPaid        Boolean   @default(false)
  paidAt        DateTime?
  isApproved    Boolean   @default(false)
  
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Pipeline {
  id            String        @id @default(cuid())
  stage         PipelineStage @default(LEAD_IDENTIFICATION)
  value         Float         @default(0)
  
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Message {
  id            String    @id @default(cuid())
  content       String
  
  senderId      String
  sender        User      @relation("SentMessages", fields: [senderId], references: [id])
  
  receiverId    String
  receiver      User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
  
  attachmentUrl String?
  
  createdAt     DateTime  @default(now())
}

enum MilestoneType {
  MILESTONE
  GOAL
  DEADLINE
  MEETING
}

model Milestone {
  id            String        @id @default(cuid())
  title         String
  description   String?
  date          DateTime
  type          MilestoneType @default(MILESTONE)
  color         String        @default("#3b82f6")
  completed     Boolean       @default(false)
  
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assignedToId  String?
  assignedTo    User?         @relation("AssignedTo", fields: [assignedToId], references: [id])
  
  createdById   String
  attachmentUrl String?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  PAID
  OVERDUE
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  subtotal      Float         @default(0)
  taxRate       Float         @default(0)
  taxAmount     Float         @default(0)
  discount      Float         @default(0)
  total         Float         @default(0)
  notes         String?
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime
  paidAt        DateTime?

  // Legacy single-line fields (kept for backward compat)
  amount        Float         @default(0)
  description   String        @default("")

  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  templateId    String?
  template      Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)

  items         InvoiceItem[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model InvoiceItem {
  id            String    @id @default(cuid())
  description   String
  quantity      Float     @default(1)
  rate          Float     @default(0)
  amount        Float     @default(0)
  
  invoiceId     String
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())
}

enum TemplateType {
  INVOICE
  EMAIL
}

model Template {
  id            String        @id @default(cuid())
  name          String
  type          TemplateType  @default(INVOICE)
  layout        String        @default("classic") // classic, modern, minimal
  colorPrimary  String        @default("#3b82f6")
  colorSecondary String       @default("#1e293b")
  logoUrl       String?
  headerText    String?
  footerText    String?
  isDefault     Boolean       @default(false)

  invoices      Invoice[]
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum ExpenseCategory {
  OPERATIONS
  MARKETING
  SALARIES
  SOFTWARE
  TRAVEL
  OFFICE
  OTHER
}

model Expense {
  id            String          @id @default(cuid())
  description   String
  amount        Float           @default(0)
  category      ExpenseCategory @default(OTHER)
  date          DateTime        @default(now())
  receipt       String?
  
  projectId     String?
  project       Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Notification {
  id            String    @id @default(cuid())
  title         String
  message       String
  isRead        Boolean   @default(false)
  link          String?

  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
}

enum PaymentType {
  ADVANCE
  MILESTONE
  FINAL
  REFUND
}

model Payment {
  id            String      @id @default(cuid())
  amount        Float
  type          PaymentType @default(ADVANCE)
  date          DateTime    @default(now())
  notes         String?
  
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
